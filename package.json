{
	"name": "cfp-test2",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev:vite": "vite",
		"dev:pages": "wrangler pages dev functions --port 8788",
		"dev": "concurrently \"pnpm dev:vite\" \"pnpm dev:pages\"",
		"dev:0": "pnpm dev:vite & pnpm dev:pages",
		"build": "tsc -b && vite build",
		"preview": "concurrently \"vite preview\" \"pnpm dev:pages\"",
		"preinstall": "pnpm audit",
		"format": "oxfmt",
		"lint": "oxlint",
		"check": "oxfmt && oxlint --fix",
		"create": "wrangler pages project create cfp-test2 --production-branch main",
		"deploy": "wrangler pages deploy",
		"trivy": "trivy config . && trivy fs .",
		"trivy-license": "trivy fs --scanners license --severity HIGH,CRITICAL ."
	},
	"dependencies": {
		"cowsay": "^1.6.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-router": "^8.0.1"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260624.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"concurrently": "^10.0.3",
		"globals": "^17.7.0",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.1.0",
		"wrangler": "^4.104.0"
	}
}
